{
  "name": "mail2dns",
  "version": "0.1.2",
  "description": "CLI that automates DNS setup for email.",
  "license": "MIT",
  "main": "dist/cli.js",
  "bin": {
    "mail2dns": "dist/cli.js"
  },
  "files": [
    "dist",
    "schema.json"
  ],
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build": "node node_modules/tsup/dist/cli-default.js && node node_modules/tsx/dist/cli.mjs scripts/export-schema.ts > schema.json",
    "dev": "node node_modules/tsx/dist/cli.mjs src/cli.ts",
    "typecheck": "node node_modules/typescript/lib/tsc.js",
    "test": "node --import tsx/esm --test tests/**/*.test.js",
    "export:schema": "node node_modules/tsx/dist/cli.mjs scripts/export-schema.ts",
    "generate:docs": "node node_modules/tsx/dist/cli.mjs scripts/generate-docs.ts"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "dns",
    "email",
    "cli",
    "mx",
    "spf",
    "dkim",
    "dmarc",
    "devops",
    "email dns",
    "dns records",
    "dns automation",
    "email setup",
    "transactional email",
    "domain email",
    "dns tool",
    "dns cli",
    "ses",
    "fastmail",
    "google workspace",
    "mailgun",
    "microsoft 365",
    "outlook",
    "migadu",
    "postmark",
    "proton mail",
    "resend",
    "sendgrid",
    "zoho mail",
    "route53",
    "azure dns",
    "cloudflare",
    "digital ocean",
    "godaddy",
    "google cloud",
    "hetzner",
    "netlify",
    "spaceship",
    "vercel"
  ]
}
